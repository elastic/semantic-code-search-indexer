# ==========================================
# ELASTICSEARCH CONFIGURATION
# ==========================================

# Connection settings
# You must provide EITHER an ENDPOINT OR a CLOUD_ID
ELASTICSEARCH_ENDPOINT=
# ELASTICSEARCH_CLOUD_ID=

# Authentication settings
# If using basic auth:
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# Or if using an API key:
# ELASTICSEARCH_API_KEY=

# Semantic text and ELSER settings
# Required unless SCSI_DISABLE_SEMANTIC_TEXT=true.
# Any custom inference ID string can be used.
# Typical values: .elser-2-elastic (for Elastic Cloud/EIS) or .elser-2-elasticsearch (for self-managed)
SCSI_ELASTICSEARCH_INFERENCE_ID=.elser-2-elastic

# Optional: Disable semantic text features for faster local testing without ELSER (defaults to false)
# SCSI_DISABLE_SEMANTIC_TEXT=false

# Connection tuning
# Optional: Elasticsearch request timeout in milliseconds (defaults to 90000)
# SCSI_ELASTICSEARCH_REQUEST_TIMEOUT=90000

# ==========================================
# INDEXER CONFIGURATION
# ==========================================

# Optional: GitHub token for cloning/pulling private repositories (or avoiding rate limits)
# GITHUB_TOKEN=

# Optional: Global language allowlist (comma-separated).
# If unset, all supported languages are used by default.
# Supported values: See `languageConfigurations` keys in `src/languages/index.ts`
# Example: SCSI_LANGUAGES=typescript,javascript,markdown
# SCSI_LANGUAGES=

# Optional: Base directory for queue databases (defaults to .queues)
# SCSI_QUEUE_BASE_DIR=.queues

# Optional: Controls which env file is loaded.
# - test: loads .env.test and suppresses console logging unless SCSI_FORCE_LOGGING=true
# - any other value (or unset): loads .env
# NODE_ENV=development

# Optional: Maximum chunk size in bytes (defaults to 1000000)
# SCSI_MAX_CHUNK_SIZE_BYTES=1000000

# Optional: Enable indexing dense vectors for code chunks (defaults to false)
# SCSI_ENABLE_DENSE_VECTORS=false

# Optional: Default chunk size in lines (defaults to 15)
# SCSI_DEFAULT_CHUNK_LINES=15

# Optional: Chunk overlap in lines (defaults to 3)
# SCSI_CHUNK_OVERLAP_LINES=3

# Optional: Markdown chunk delimiter regex pattern (defaults to \n\s*\n)
# SCSI_MARKDOWN_CHUNK_DELIMITER=\n\s*\n

# Optional: Force logging output even in test environments (defaults to false)
# SCSI_FORCE_LOGGING=false

# Test-only indexing hooks used by integration tests
# Force a one-time indexing failure when a chunk from the given file path is present
# SCSI_TEST_INDEXING_THROW_ON_FILEPATH=
# Add an artificial indexing delay in milliseconds
# SCSI_TEST_INDEXING_DELAY_MS=0

# ==========================================
# OPENTELEMETRY (OTEL) CONFIGURATION
# ==========================================

# Enable sending logs to OpenTelemetry (defaults to false)
# SCSI_OTEL_LOGGING_ENABLED=false
# OTEL_SERVICE_NAME=semantic-code-search-indexer
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer token
# Enable sending metrics to OpenTelemetry
# Defaults to the value of SCSI_OTEL_LOGGING_ENABLED when unset
# SCSI_OTEL_METRICS_ENABLED=false
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
# SCSI_OTEL_METRIC_EXPORT_INTERVAL_MILLIS=60000
# OTEL_LOG_LEVEL=info
# Allowed values: debug, info, warn, error
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=staging,team=platform,custom.key=custom-value
