SCSI_ES_ENDPOINT=
SCSI_ES_CLOUD_ID=
SCSI_ES_USERNAME=
SCSI_ES_PASSWORD=
SCSI_ES_API_KEY=
# Required unless SCSI_DISABLE_SEMANTIC_TEXT=true.
# Recommended: use EIS-backed ELSER on Elastic Cloud.
SCSI_ES_INFERENCE_ID=.elser-2-elastic

# GitHub token for cloning/pulling private repositories
SCSI_GITHUB_TOKEN=

# Optional: Global language allowlist (comma-separated).
# This is used as the default when `--languages` is not provided.
# Example: SCSI_LANGUAGES=typescript,javascript,markdown
# SCSI_LANGUAGES=

# OpenTelemetry Configuration
SCSI_OTEL_LOGGING_ENABLED=false
SCSI_OTEL_SERVICE_NAME=semantic-code-search-indexer
SCSI_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# SCSI_OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
# SCSI_OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer token

# Optional: Base directory for queue databases (defaults to .queues)
# SCSI_QUEUE_BASE_DIR=.queues

# Optional: Controls which env file is loaded:
# - NODE_ENV=test loads .env.test
# - otherwise loads .env
# NODE_ENV=development
