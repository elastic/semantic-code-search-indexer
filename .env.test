# Integration test environment variables
# This file is used by tests when NODE_ENV=test

SCSI_ES_ENDPOINT=http://localhost:9200
SCSI_ES_USERNAME=elastic
SCSI_ES_PASSWORD=testpassword

# The setup-integration-tests.sh script provisions this endpoint
SCSI_ES_INFERENCE_ID=elser-inference-test

# Disable ELSER semantic_text field for faster testing
# This tests the indexing pipeline without the expensive ML inference.
# Note: With SCSI_DISABLE_SEMANTIC_TEXT=true, semantic search functionality is NOT tested in integration tests.
# For full ELSER validation, see the manual test plan in docs/.
SCSI_DISABLE_SEMANTIC_TEXT=true

# SCSI_ES_REQUEST_TIMEOUT is kept higher for safety
SCSI_ES_REQUEST_TIMEOUT=120000
