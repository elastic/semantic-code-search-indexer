  {
    "chunk_hash": "9181590ddf5f355ec8200bd56277209f13a8336cd694c54badc79054f8328674",
    "containerPath": "",
    "content": "parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -d|--debug)
                DEBUG_MODE=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
        esac
    done
}",
    "created_at": "[TIMESTAMP]",
