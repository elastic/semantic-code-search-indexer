  {
    "chunk_hash": "9074cd4ce627137675473943faa275b0295e623c5fe4827e6ab2f4237c94f265",
    "containerPath": "",
    "content": "process_files() {
    local dir="$1"
    
    if [[ ! -d "$dir" ]]; then
        echo "Error: Directory not found: $dir" >&2
        return 1
    fi
    
    for file in "$dir"/*; do
        if [[ -f "$file" ]]; then
            echo "Processing: $(basename "$file")"
        fi
    done
}",
    "created_at": "[TIMESTAMP]",
    "directoryDepth": 2,
    "directoryName": "fixtures",
