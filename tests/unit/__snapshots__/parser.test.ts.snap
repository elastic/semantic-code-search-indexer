  {
    "chunk_hash": "d50662ceb1061044d1d7db2bb2177665696234c0228f189b25f853afbd534037",
    "containerPath": "",
    "content": "calculate() {
    local a="$1"
    local b="$2"
    local result
    
    case "$3" in
        add)
            result=$((a + b))
            ;;
        subtract)
            result=$((a - b))
            ;;
        multiply)
            result=$((a * b))
            ;;
        *)
            echo "Unknown operation" >&2
            return 1
            ;;
    esac
    
    echo "$result"
}",
