    "semantic_text": "filePath: tests/fixtures/bash.sh
directoryPath: tests/fixtures
kind: function_definition

process_files() {
    local dir="$1"
    
    if [[ ! -d "$dir" ]]; then
        echo "Error: Directory not found: $dir" >&2
        return 1
    fi
    
    for file in "$dir"/*; do
        if [[ -f "$file" ]]; then
            echo "Processing: $(basename "$file")"
        fi
    done
}",
